// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

enum Role {
  SUPER_ADMIN
  ADMIN
}

model AdminUser {
  id                 Int       @id @default(autoincrement())
  name               String
  email              String    @unique
  password           String
  role               Role      @default(ADMIN)
  reset_token        String?   @unique
  reset_token_expiry DateTime?
  update_at          DateTime? @updatedAt
  created_at         DateTime  @default(now())

  @@map("admin_user")
}

model User {
  id           Int       @id @default(autoincrement())
  name         String
  first_name   String
  last_name    String
  email        String    @unique
  mobile       String
  designation  String?
  organization String?
  address      String?
  city         String?
  state        String?
  pincode      String
  update_at    DateTime? @updatedAt
  created_at   DateTime  @default(now())

  @@map("user")

  @@index([email])
}
